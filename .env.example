# SentinelCore Environment Configuration
# Copy this file to .env and fill in real values.
# NEVER commit the actual .env file to version control.

# ─── Cloud Telemetry Endpoint ─────────────────────────────────────────────────
SENTINEL_CLOUD_ENDPOINT=https://your-telemetry-endpoint.example.com

# ─── Device Identity ─────────────────────────────────────────────────────────
SENTINEL_DEVICE_ID=your-device-uuid-here

# ─── Audit Log Path (override default data/security_audit.log) ───────────────
SENTINEL_AUDIT_LOG_PATH=data/security_audit.log

# ─── Watchdog Restart Policy ─────────────────────────────────────────────────
SENTINEL_WATCHDOG_RESTART_DELAY_SECS=5
